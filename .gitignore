# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# data and results folder
data/*
Original_Data/*
Figures/*
Results/*
Original Data/*
Export_Files/*
original_data/*

# .DS_store
.DS_Store


# ============================================================
# LaTeX Temporary Files  .gitignore Template
# ============================================================

# --- Core compilation artifacts ---
*.aux          # Cross-references, citations
*.log          # Compiler log
*.out          # Hyperref bookmarks (hyperref package)
*.toc          # Table of contents
*.lof          # List of figures
*.lot          # List of tables
*.fls          # File list (latexmk)
*.fdb_latexmk  # latexmk dependency database
*.synctex.gz   # SyncTeX (editor ↔ PDF sync)
*.synctex(busy)

# --- Bibliography ---
*.bbl          # Processed bibliography
*.blg          # BibTeX log
*.bcf          # Biber control file
*.run.xml       # Biber run file

# --- Index & glossary ---
*.idx          # Raw index
*.ilg          # Index log
*.ind          # Processed index
*.glo          # Glossary entries
*.gls          # Processed glossary
*.glg          # Glossary log
*.acn          # Acronym entries (glossaries package)
*.acr          # Processed acronyms
*.alg          # Acronym log
*.ist          # Index style (makeindex)

# --- Nomenclature ---
*.nlo          # Nomenclature entries
*.nls          # Processed nomenclature

# --- Cross-references & counters ---
*.lol          # List of listings (listings package)
*.nav          # Beamer navigation symbols
*.snm          # Beamer slide numbers
*.vrb          # Beamer verbatim
*.brf          # Backref (backref package)
*.maf          # minitoc main file
*.mtc*         # minitoc chapter files
*.mlf*         # minitoc lof files
*.mlt*         # minitoc lot files

# --- Code listings ---
*.pyg          # Pygments (minted package)
_minted-*/     # minted temp directory

# --- PGF / TikZ externalization ---
*.dpth
*.md5
*.auxlock
/figures/externalized/

# --- latexmk / arara / build tools ---
*.deps
*.makefile

# --- Intermediate PDF (if using -output-directory) ---
# Uncomment if you keep the final PDF committed:
# *.pdf

# --- Editor-specific ---
# TeXstudio
*.bak
# Overleaf sync artifacts (if applicable)
.overleaf/

# --- OS noise ---
.DS_Store
Thumbs.db

CLAUDE.md